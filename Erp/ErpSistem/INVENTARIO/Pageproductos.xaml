                           />
                    <ComboBox x:Name="cbx_categoria"
                              IsTextSearchEnabled="True" HorizontalAlignment="Left" Margin="98,86,0,0" VerticalAlignment="Top" Width="216" DisplayMemberPath="nombre" SelectedValuePath="codigo"  SelectedIndex="0"  Height="30" FontFamily="Arial" FontSize="14"/>
                    <Label x:Name="label_Copy4" Content="Categoria" HorizontalAlignment="Left" Margin="10,81,0,0" VerticalAlignment="Top" Width="88" Height="33" FontSize="17" RenderTransformOrigin="0.643,0.4" FontWeight="Bold" 
                          />
                    <TextBox x:Name="codigo" HorizontalAlignment="Left" Height="32" Margin="98,9,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="76" FontSize="15" Visibility="Visible" IsEnabled="False" FontWeight="Bold" />
                    <Label x:Name="label_Copy2" Content="Precio" HorizontalAlignment="Left" Margin="15,119,0,0" VerticalAlignment="Top" Width="89" Height="31" FontSize="17" FontWeight="Bold" 
                           />
