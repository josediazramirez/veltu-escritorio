                            <DataGridTextColumn Header="Id" Binding="{Binding id}"  Width="85" FontSize="13"  />
                            <DataGridTextColumn Header="Fecha y hora" Binding="{Binding fecha_hora}" Width="85"  FontSize="13" />
                            <DataGridTextColumn Header="Ubicación" Binding="{Binding ubicacion}" Width="130"  FontSize="13" />
                            <DataGridTextColumn Header="SKU" Binding="{Binding cod_pro}" Width="80"  FontSize="13" />
                            <DataGridTextColumn Header="Producto" Binding="{Binding nombre_pro}" Width="170"  FontSize="13" />
                            <DataGridTextColumn Header="Moviemiento" Binding="{Binding movimiento}" Width="150"  FontSize="13">
                                <DataGridTextColumn.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Background" Value="{Binding mov_color}" />
                                        <Setter Property="Width" Value="150"/>
                                        <Setter Property="Height" Value="30"/>
                                    </Style>
                                </DataGridTextColumn.CellStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Cant.Mov" Binding="{Binding cantidad}" Width="120"  FontSize="13" />
                            <DataGridTextColumn Header="Stock anterior" Binding="{Binding stock_ant}" Width="150"  FontSize="13" />
                            <DataGridTextColumn Header="Stock actual" Binding="{Binding stock_act}" Width="150"  FontSize="13" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="TRANSFERENCIA BODEGA" x:Name="trans_menu">
                <Grid >
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"></RowDefinition>
                        <RowDefinition Height="auto"></RowDefinition>
                        <RowDefinition Height="auto"></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid  x:Name="gr_header">
                        <StackPanel Orientation="Horizontal">
                            <Label Foreground="Black" FontSize="20" Content="TRANSFERENCIA DE BODEGA"></Label>
                            <Label x:Name="fecha_actual" Foreground="Black" FontSize="20" ></Label>
                        </StackPanel>
                    </Grid>
                    <Grid Grid.Row="1" x:Name="gr_body">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"></RowDefinition>
                            <RowDefinition Height="auto"></RowDefinition>
                            <RowDefinition Height="auto"></RowDefinition>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <StackPanel   Orientation="Horizontal" Margin="10">
                            <Label FontSize="16">Desde</Label>
                            <ComboBox  DisplayMemberPath="nombre"  SelectedValuePath="idcentro"
                                       SelectedIndex="0" Width="150" x:Name="cbx_desde" ></ComboBox>
                        </StackPanel>
                        <StackPanel  Grid.Column="1" Orientation="Horizontal" Margin="10">
                            <Label FontSize="16">Hacia</Label>
                            <ComboBox  DisplayMemberPath="nombre" SelectedValuePath="idcentro" 
                                       SelectedIndex="0" Width="150" x:Name="cbx_hasta" ></ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="10">
                            <Label FontSize="16">Comentario</Label>
                            <TextBox Height="50" FontSize="18" x:Name="tbx_comentario" ></TextBox>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Grid.Column="2" Margin="0,30,0,0">
                            <Button Height="40" Margin="10" x:Name="CancelarTransferencia" Click="CancelarTransferencia_Click">Cancelar</Button>
                            <Button Height="40" Margin="10" x:Name="AgregarProductoTransferencia" Click="AgregarProductoTransferencia_Click">Agregar producto</Button>
                            <Button Height="40" Margin="10" x:Name="RealizarTransferencia" Click="RealizarTransferencia_Click">Realizar transferencia</Button>
                        </StackPanel>
                    </Grid>
                    <Grid Grid.Row="2">
                        <DataGrid x:Name="tabla_tranfer_pro" Grid.Row="3" Grid.ColumnSpan="2" IsReadOnly="True" SelectionMode="Single" CanUserAddRows="False" AutoGenerateColumns="False" Margin="10" FontWeight="Bold" FontSize="15">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn   CanUserResize="False" Width="70">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button x:Name="btn_pro_tran_eliminar" Click="btn_pro_tran_eliminar_Click"  Content="Eliminar"  FontSize="10"  />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Codigo" Binding="{Binding codigo}"  Width="150" FontSize="13"  />
                                <DataGridTextColumn Header="Cant.Mov" Binding="{Binding total}" Width="120"  FontSize="13" />
                                <DataGridTextColumn Header="Producto" Binding="{Binding producto}" Width="400"  FontSize="13" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>
