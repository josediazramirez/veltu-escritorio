                    <Label x:Name="validar_categoria"  HorizontalAlignment="Left" Margin="260.4,81,0,0" VerticalAlignment="Top" Width="24" Height="31" FontSize="24" FontWeight="Bold" Foreground="Red">
                    </Label>
                    <Label x:Name="validar_precio"  HorizontalAlignment="Left" Margin="264.4,120,0,0" VerticalAlignment="Top" Width="24" Height="31" FontSize="24" FontWeight="Bold" Foreground="Red" />
                    <Label x:Name="label_Copy1" Content="filtro" HorizontalAlignment="Left" Margin="-1,165,0,0" VerticalAlignment="Top" Width="89" Height="31" FontSize="17" FontWeight="Bold"/>
                    <Label x:Name="label_Copy5" Content="EAN" HorizontalAlignment="Left" Margin="220.2,10,0,0" VerticalAlignment="Top" Width="89" Height="31" FontSize="17" FontWeight="Bold"/>
                    <TextBox x:Name="tb_ean" HorizontalAlignment="Left" Height="32" Margin="276.2,11,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="174" FontSize="14" FontFamily="Arial"/>
                    <TextBox x:Name="tb_filtro_producto" HorizontalAlignment="Left" Height="32" Margin="64,164,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="208" FontSize="17" FontFamily="Arial" KeyUp="TextBox_TextChanged"/>
                    <Label x:Name="label_Copy6" Content="MARCA" HorizontalAlignment="Left" Margin="463,46,0,0" VerticalAlignment="Top" Width="89" Height="31" FontSize="17" FontWeight="Bold"/>
                    <Label x:Name="label_Copy7" Content="COLOR" HorizontalAlignment="Left" Margin="462,80,0,0" VerticalAlignment="Top" Width="89" Height="31" FontSize="17" FontWeight="Bold"/>

                    <ComboBox x:Name="cbx_marca" SelectedValuePath="idmarca" HorizontalAlignment="Left" Margin="562,46,0,0" VerticalAlignment="Top" Width="208" DisplayMemberPath="nombre"  SelectedIndex="0"  Height="30" FontFamily="Arial" FontSize="14"/>
                    <Button x:Name="btn_add_mar" Content="agregar marca"  HorizontalAlignment="Left" Margin="782,46,0,0" VerticalAlignment="Top"    Height="30" FontFamily="Arial" FontSize="14" Click="btn_add_mar_Click"/>

                    <ComboBox x:Name="cbx_color" SelectedValuePath="idcolor" HorizontalAlignment="Left" Margin="562,81,0,0" VerticalAlignment="Top" Width="208" DisplayMemberPath="nombre" SelectedIndex="0"  Height="30" FontFamily="Arial" FontSize="14"/>
                    <Button x:Name="btn_add_color" Content="agregar color"  HorizontalAlignment="Left" Margin="782,81,0,0" VerticalAlignment="Top" Height="30" FontFamily="Arial" FontSize="14" Click="btn_add_color_Click"/>

                    <Label x:Name="label_nombre" Content="Nombre" HorizontalAlignment="Left" Margin="9,52,0,0" VerticalAlignment="Top" Width="89" Height="31" FontSize="17" FontWeight="Bold"/>
